{
  "name": "@rehabos/ai-assessment-engine",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered assessment interpretation engine for RehabOS",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf ./dist"
  },
  "dependencies": {
    "openai": "^4.0.0"
  },
  "devDependencies": {
    "@rehabos/tsconfig": "workspace:*",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  }
}
